# This file is consumed by the backend container.
ENV_FILE=True

# OpenAI-compatible LLM endpoint. Local Ollama/vLLM examples usually expose /v1.
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
CORE_LLM_EXTRACTION_MODE=json_text
CORE_EXTRACTION_MAX_CONCURRENCY=4

# Optional model overrides for downstream assistants and reports.
GOAL_COPILOT_LLM_MODEL=
MATERIAL_REVIEW_LLM_MODEL=

# OpenAI-compatible embedding endpoint.
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_API_KEY=

# Same-origin Docker deployment does not require browser CORS.
CORS_ALLOWED_ORIGINS=
