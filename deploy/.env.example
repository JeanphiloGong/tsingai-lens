COMPOSE_PROJECT_NAME=tsingai-lens

# Use a released Lens tag. The same tag is used for backend and frontend images.
LENS_VERSION=v0.10.1

# Browser entrypoint exposed on the host.
LENS_HTTP_PORT=8080

# Required before first start. Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=

# Override only when publishing images under another registry or namespace.
LENS_BACKEND_IMAGE=jeanphilo/tsingai-lens-backend
LENS_FRONTEND_IMAGE=jeanphilo/tsingai-lens-frontend
