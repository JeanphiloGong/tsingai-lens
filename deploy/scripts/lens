#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
ROOT_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
COMPOSE_FILE="$ROOT_DIR/compose.yml"
ENV_FILE="$ROOT_DIR/.env"
BACKEND_ENV_FILE="$ROOT_DIR/backend.env"

usage() {
  cat <<'USAGE'
Usage: lens <command> [args]

Commands:
  up             Create missing env files and start Lens.
  down           Stop Lens containers.
  restart        Restart Lens containers.
  pull           Pull configured Lens images.
  logs [args]    Follow container logs.
  ps             Show container status.
  config         Render the Docker Compose config.
  doctor         Check local deploy prerequisites and runtime health.
  upgrade TAG    Set LENS_VERSION, pull images, and restart.
  url            Print the local Lens URL.
USAGE
}

die() {
  printf 'lens: %s\n' "$*" >&2
  exit 1
}

ensure_compose() {
  command -v docker >/dev/null 2>&1 || die "docker is required"
  docker compose version >/dev/null 2>&1 || die "docker compose plugin is required"
}

ensure_env_files() {
  [ -f "$ENV_FILE" ] || cp "$ROOT_DIR/.env.example" "$ENV_FILE"
  [ -f "$BACKEND_ENV_FILE" ] || cp "$ROOT_DIR/backend.env.example" "$BACKEND_ENV_FILE"
  mkdir -p "$ROOT_DIR/data/backend"
}

compose() {
  ensure_compose
  docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

load_env() {
  if [ -f "$ENV_FILE" ]; then
    set -a
    . "$ENV_FILE"
    set +a
  fi
}

command="${1:-}"
[ "$command" ] || {
  usage
  exit 0
}
shift || true

case "$command" in
  up)
    ensure_env_files
    compose up -d "$@"
    ;;
  down)
    ensure_env_files
    compose down "$@"
    ;;
  restart)
    ensure_env_files
    compose restart "$@"
    ;;
  pull)
    ensure_env_files
    compose pull "$@"
    ;;
  logs)
    ensure_env_files
    compose logs -f "$@"
    ;;
  ps)
    ensure_env_files
    compose ps "$@"
    ;;
  config)
    ensure_env_files
    compose config "$@"
    ;;
  doctor)
    "$SCRIPT_DIR/doctor.sh" "$@"
    ;;
  upgrade)
    "$SCRIPT_DIR/upgrade.sh" "$@"
    ;;
  url)
    load_env
    printf 'http://localhost:%s\n' "${LENS_HTTP_PORT:-8080}"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    die "unknown command: $command"
    ;;
esac
